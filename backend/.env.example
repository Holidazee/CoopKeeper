ENV=dev
APP_ENV=local
APP_TITLE=CoopKeeper API
APP_VERSION=1.0.0

DATABASE_URL=postgresql+psycopg://appuser:apppass123@localhost:5433/coopkeeper
SECRET_KEY=replace-this-in-staging-and-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Optional legacy setting when serving the frontend through FastAPI at /app.
FRONTEND_API_BASE_URL=

# Comma-separated origins for browsers that call the API from another domain.
# Production example: https://coopkeeper.net,https://www.coopkeeper.net
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000

HOST=0.0.0.0
PORT=8000
WEB_CONCURRENCY=1
